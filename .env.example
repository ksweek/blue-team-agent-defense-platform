# Copy this file to `.env` before local or Docker startup.

# Deployment profile
# `development`: local demo defaults with runtime auto-bootstrap.
# `production`: runtime processes must not auto-migrate or auto-seed; use
# `python backend/scripts/init_db.py --mode schema` before service startup.
APP_ENV=development
BOOTSTRAP_MODE=auto

# Local default: SQLite
DATABASE_URL=sqlite:///backend/data/app.db

# To use PostgreSQL instead, replace DATABASE_URL with something like:
# DATABASE_URL=postgresql+psycopg://blue_team:blue_team_pw@127.0.0.1:5432/blue_team

DATABASE_ECHO=false
DATABASE_POOL_PRE_PING=true

# Local bootstrap users. These are only created when the `users` table is empty.
# In production, replace both passwords before any bootstrap command is run.
BOOTSTRAP_ADMIN_PASSWORD=admin123
BOOTSTRAP_ANALYST_PASSWORD=analyst123

JWT_SECRET=blue-team-dev-secret
JWT_EXPIRE_MINUTES=480

# Gateway service authentication
# Service-to-service callers can use this token with `X-Gateway-Token`
# or `Authorization: Bearer <token>` when they do not use platform JWT login.
# Runtime callback endpoints now reuse normal platform login and no longer need
# a separate callback secret.
GATEWAY_API_TOKEN=blue-team-runtime-token

# AI task execution
# Set AI_PROVIDER to `openai_compatible` to enable a real chat-completions provider.
# Keep it `disabled` for rule-only execution without live AI review.
AI_PROVIDER=disabled
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=
AI_TIMEOUT_SECONDS=60
AI_TEMPERATURE=0
AI_MAX_TOKENS=1200
# Sample seed data
# `true`: preload demo audit logs / assets / tasks / reports for local evaluation
# `false`: only seed baseline users + configuration defaults
SEED_SAMPLE_DATA=true

# Worker mode
# Keep TASK_WORKER_EMBEDDED=true for the default single-process mode.
# Set TASK_WORKER_EMBEDDED=false when you start a separate worker process or
# `docker compose --profile external-worker up -d`.
TASK_WORKER_EMBEDDED=true
TASK_WORKER_CONCURRENCY=1
TASK_WORKER_POLL_INTERVAL=0.5
TASK_WORKER_RECOVERY_LIMIT=200
TASK_WORKER_HEARTBEAT_INTERVAL=5
TASK_WORKER_STALE_SECONDS=180
TASK_WORKER_RETRY_DELAY_SECONDS=10
TASK_WORKER_MAX_ATTEMPTS=3

# Skill scanning
# `local`: built-in static skill scanner
# `agent_scan`: local scanner + optional Snyk agent-scan CLI
SKILL_SCAN_PROVIDER=local
SKILL_SCAN_AGENT_SCAN_BIN=agent-scan
SKILL_SCAN_TIMEOUT_SECONDS=120
SKILL_SCAN_MAX_FILES=80
SKILL_SCAN_MAX_FILE_BYTES=262144

POSTGRES_DB=blue_team
POSTGRES_USER=blue_team
POSTGRES_PASSWORD=blue_team_pw
